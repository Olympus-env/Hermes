# --- HERMES configuration ---
# Copier en .env et adapter

# Backend
HERMES_HOST=127.0.0.1
HERMES_PORT=8000
HERMES_DEBUG=true

# Base de données (chemin SQLite)
HERMES_DB_PATH=./data/hermes.db

# Stockage des documents téléchargés
HERMES_STORAGE_PATH=./data/storage

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=mistral:7b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text

# Logs
HERMES_LOG_LEVEL=INFO
HERMES_LOG_PATH=./data/logs

# Sécurité : clé maître (sera générée automatiquement au premier démarrage si absente)
# HERMES_MASTER_KEY=
# HERMES_MASTER_KEY_PATH=./data/master.key
